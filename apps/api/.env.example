NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# DB backend: lakebase | sqlite | auto (default)
DB_BACKEND=sqlite
# Local dev SQLite path (defaults to ./data/lakecost.db at repo root if unset)
# SQLITE_PATH=./data/lakecost.db

# Databricks Apps will inject these at runtime; set them locally to test
# DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
# DATABRICKS_CLIENT_ID=
# DATABRICKS_CLIENT_SECRET=
# SQL_WAREHOUSE_ID=

# Lakebase (optional, set when DB_BACKEND=lakebase or auto)
# LAKEBASE_INSTANCE_NAME=
# PGHOST=
# PGDATABASE=lakecost
# PGUSER=
# PGPORT=5432
# PGSSLMODE=require
# LAKEBASE_ENDPOINT=
